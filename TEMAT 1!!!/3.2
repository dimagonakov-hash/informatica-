#include <iostream>
using namespace std;

int main() {
    double c;
    char wybor;

    cout << "Podaj temperature w stopniach Celsjusza: ";
    cin >> c;

    cout << "Wybierz jednostke (K - Kelvin, F - Fahrenheit): ";
    cin >> wybor;

    switch (wybor) {
        case 'K':
        case 'k':
            cout << "Temperatura w Kelvinach: " << c + 273.15 << endl;
            break;

        case 'F':
        case 'f':
            cout << "Temperatura w Fahrenheitach: " << (c * 9/5) + 32 << endl;
            break;

        default:
            cout << "Nieprawidlowy wybor!" << endl;
    }

    return 0;
}